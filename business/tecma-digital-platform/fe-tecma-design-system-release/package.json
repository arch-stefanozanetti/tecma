{
  "name": "@tecma/ds",
  "version": "1.116.0",
  "description": "Tecma Design System",
  "main": "lib/index.cjs.js",
  "module": "lib/index.esm.js",
  "types": "lib/index.d.ts",
  "private": false,
  "scripts": {
    "start": "react-scripts start",
    "build": "rollup -c rollup.config.js",
    "createComponent": "node .generate_component",
    "createStories": "node .generate_stories",
    "createStyle": "node .generate_style",
    "prepublish": "yarn build",
    "test": "react-scripts test",
    "format": "prettier --ignore-path .prettierignore \"**/*.+(ts|js|tsx)\" --write",
    "test:coverage": "nyc --clean react-scripts test --ci --reporters=default --reporters=jest-junit --coverage a --coverageReporters=json",
    "test:type": "tsc --noEmit && eslint . --ext ts,tsx --fix",
    "lint": "eslint . --fix && prettier . --write",
    "init-husky": "husky install",
    "storybook": "start-storybook -p 6006 -s public",
    "build-storybook": "build-storybook -s public",
    "import-icons": "node .import_icons",
    "test-storybook": "test-storybook --coverage"
  },
  "peerDependencies": {
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
