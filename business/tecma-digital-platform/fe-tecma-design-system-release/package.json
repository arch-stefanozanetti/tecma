  "lint-staged": {
    "./src/**/*.{ts,js,jsx,tsx,json}": [
      "yarn run format",
      "yarn run test:type",
      "yarn run validate-branch-name"
    ]
  },
  "files": [
    "/lib"
  ],
  "publishConfig": {
    "@tecma:registry": "https://gitlab.tecmasolutions.com/api/v4/projects/155/packages/npm/"
  },
  "resolutions": {
    "@storybook/react-docgen-typescript-plugin": "1.0.6--canary.9.cd77847.0",
    "@types/react": "^17.0.0"
  },
  "validate-branch-name": {
    "pattern": "^(feat)(/[a-z-]+){1,2}$|^(bugfix)/[a-z-]+$|^(chore)/[a-z-]+$|^(docs)/[a-z-]+$",
    "errorMsg": "There is something wrong with your branch name. Your commit will be rejected. You should rename your branch to a valid name and try again."
  },
