VITE_BUSINESSPLATFORM_LOGIN=https://businessplatform-biz-tecma-dev1.tecmasolutions.com/login

# Proxy dev/preview → backend (default http://127.0.0.1:8080; usa 127.0.0.1 per evitare mismatch IPv6 localhost su macOS).
# VITE_PROXY_TARGET=http://127.0.0.1:8080
#
# Base URL delle API. In locale NON impostare: il proxy Vite inoltra /v1 al target sopra.
# Render (FE statico + BE separato): includere sempre /v1 finale:
#   VITE_API_BASE_URL=https://followup-3-be.onrender.com/v1
# Sul servizio BE Render: APP_PUBLIC_URL=https://followup-3-fe.onrender.com (altrimenti CORS → "Failed to fetch").
# Gateway Tecma:
#   dev-1:  https://api.tecmasolutions.com/biz-tecma-dev1/v1
# VITE_API_BASE_URL=

# Link o mailto per contatto commerciale Tecma (Integrazioni / footnote connettori). Opzionale.
# VITE_TECMA_COMMERCIAL_CONTACT_URL=https://www.tecmasolutions.com/contatti
# VITE_TECMA_COMMERCIAL_CONTACT_LABEL=Contatta Tecma

# Auth tramite gateway BSS (single sign-on piattaforma). Opzionale, default false.
# Se true: il FE usa POST /login (BSS) e POST /v1/users/getUserByJWT come "me", refresh con /v1/auth/refresh-token.
# Richiede VITE_API_BASE_URL verso api.tecmasolutions.com. Vedi docs/BSS_INTEGRATION.md.
# VITE_USE_BSS_AUTH=false
