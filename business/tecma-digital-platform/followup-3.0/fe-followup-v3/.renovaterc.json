{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard"
  ],
  "labels": [
    "dependencies",
    "automated"
  ],
  "timezone": "Europe/Rome",
  "schedule": [
    "before 6am on monday"
  ],
  "rangeStrategy": "replace",
  "packageRules": [
    {
      "description": "Group all non-major updates",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest",
        "pin"
      ],
      "groupName": "all non-major dependencies",
      "automerge": false
    },
    {
      "description": "Security updates are separate and immediate",
      "matchUpdateTypes": [
        "security"
      ],
      "groupName": "security dependencies",
      "automerge": false
    },
    {
      "description": "Major updates isolated for manual review",
      "matchUpdateTypes": [
        "major"
      ],
      "separateMajorMinor": true,
      "dependencyDashboardApproval": true,
      "automerge": false
    }
  ],
  "prConcurrentLimit": 8,
  "prHourlyLimit": 2,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security",
      "dependencies"
    ]
  }
}
