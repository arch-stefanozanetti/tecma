{
  "name": "fe-followup-v3",
  "version": "0.13.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "release": "semantic-release",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:core": "vitest run -c vitest.core.config.ts --coverage",
    "test:e2e": "playwright test",
    "test:e2e:core": "playwright test e2e/core --project=chromium",
    "test:e2e:enterprise": "playwright test e2e/core/enterprise-journeys.spec.ts --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test e2e/visual",
    "test:a11y": "playwright test e2e/a11y",
    "check:panels": "node ./scripts/panel-guard.mjs",
    "check:detail-architecture": "node ./scripts/check-detail-architecture.mjs",
    "check:bundle-budget": "node ./scripts/check-bundle-budget.mjs",
    "generate-pwa-icons": "node ./scripts/generate-pwa-icons.mjs",
    "check:lighthouse-pwa": "node ./scripts/lighthouse-pwa.mjs",
    "test:panels": "vitest run -c vitest.panels.config.ts",
    "test:lint": "eslint src",
    "test:lint:core": "eslint src/api src/auth src/core/clients src/core/apartments src/core/requests src/components src/hooks src/lib src/App.tsx"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.8",
    "@radix-ui/react-avatar": "^1.1.11",
