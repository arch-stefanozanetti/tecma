PORT=5060
# APP_ENV: ambiente (default dev-1). Per deploy, impostare per ogni ambiente.
APP_ENV=dev-1
# MONGO_URI: per ogni ambiente usare l'URI del cluster corrispondente.
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=tecma_dev1
MONGO_CLIENT_DB_NAME=client
MONGO_USER_DB_NAME=user
MONGO_PROJECT_DB_NAME=project
AUTH_JWT_SECRET=dev-followup-secret-change-me
AUTH_JWT_EXPIRES_IN=15m
# Refresh token validity in days (default 7)
AUTH_REFRESH_EXPIRES_DAYS=7
