PORT=8080
# APP_ENV: ambiente (default dev-1). Per deploy, impostare per ogni ambiente.
APP_ENV=dev-1
# MONGO_URI: cluster MongoDB. Se l'URI termina con /test, quello è spesso solo il default auth DB;
# i dati dell'app stanno in client.db(MONGO_DB_NAME) — impostare sempre MONGO_DB_NAME coerente.
MONGO_URI=mongodb://localhost:27017
# DB operativo Followup (es. ambiente dev: test-zanetti). Non usare più il DB legacy "test" salvo migrazione.
MONGO_DB_NAME=test-zanetti
# Migrazione dati test → test-zanetti: Atlas / mongodump oppure script unifyMainDb (one-off in src/utils).
# cloneUserFromSourceDb: copia un utente in tz_users solo se l'email esiste già nella collection utenti del DB sorgente (SOURCE_*).
# Clone utente → tz_users su test-zanetti (npm run clone-user-from-source -- email@...)
# Default: stesso MONGO_URI, database sorgente "tecma". Opzionale:
# SOURCE_MONGO_URI=...   # altro cluster (es. read-only prod)
# SOURCE_MONGO_DB_NAME=tecma
# Clone admin legacy → Followup: user.adminUsers → test-zanetti.tz_users (solo scrittura su test-zanetti)
# npm run clone-adminusers-to-tz-users
AUTH_JWT_SECRET=dev-followup-secret-change-me
# In produzione/staging (APP_ENV=production|prod|staging o NODE_ENV=production): min 32 caratteri, non il default.
# Webhook POST /v1/contracts/signature-requests/webhook: stesso valore in Authorization Bearer o header x-signature-webhook-secret.
# In produzione/staging: obbligatorio, minimo 16 caratteri.
SIGNATURE_WEBHOOK_SECRET=dev-signature-webhook-change-me-16
# Opzionale: IP o CIDR IPv4 (virgola) ammessi per POST webhook firme oltre al segreto. Vuoto = nessun filtro IP.
# SIGNATURE_WEBHOOK_ALLOWED_CIDRS=203.0.113.0/24,198.51.100.10
# In ambienti production-like: false per non esporre /docs e /openapi.json pubblicamente.
# PUBLIC_API_DOCS_ENABLED=true
# Feed MLS GET /v1/mls/feed/...: chiave via header x-mls-api-key (preferito) o query apiKey.
AUTH_JWT_EXPIRES_IN=15m
# Refresh token validity in days (default 7)
AUTH_REFRESH_EXPIRES_DAYS=7

# Fallback link invito/reset + origine CORS del frontend (deve coincidere con l'URL da cui apri l'app).
# Render: https://followup-3-fe.onrender.com — se resta localhost, il sito su Render avrà "Failed to fetch".
APP_PUBLIC_URL=http://localhost:5177
# Origini CORS extra (virgola), es. test locale verso API Render: http://localhost:5177,http://127.0.0.1:5177
# CORS_ORIGINS=
# Opzionale: altri host ammessi per il link invito (dominio custom), es. app.azienda.it
# INVITE_LINK_ALLOWED_HOSTS=app.azienda.it
# SSO /auth/sso-exchange: obbligatorio uno tra JWKS (IdP) o segreto HS256 (gateway)
# SSO_JWKS_URI=https://your-idp/.well-known/jwks.json
# SSO_JWT_ISSUER=https://your-idp/
# SSO_JWT_AUDIENCE=your-api-audience
# oppure: SSO_JWT_HS256_SECRET=shared-secret-with-gateway
EMAIL_FROM=Followup <noreply@verified-domain.example.com>
# mock = nessun invio reale; smtp = AWS SES (obbligatorio per inviti in produzione)
EMAIL_TRANSPORT=mock
# Solo test/sviluppo senza SES: consente POST /users con mock (nessuna mail). In prod lasciare assente o false.
# INVITE_ALLOW_MOCK_EMAIL=true
SES_SMTP_HOST=email-smtp.eu-central-1.amazonaws.com
SES_SMTP_PORT=587
# SES_SMTP_USER=
# SES_SMTP_PASS=
#
# Comunicazioni CRM (template/regole in Integrazioni → Comunicazioni). Non è lo stesso stack degli inviti utenti.
# SMTP_HOST=smtp.example.com
# SMTP_FROM=Followup Comms <noreply@example.com>
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false
INVITE_TOKEN_EXPIRES_HOURS=168
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=60
# Editor email a blocchi: host https consentiti per logo/immagini (virgola). Dev: * = qualsiasi https.
# EMAIL_ASSET_URL_HOSTS=cdn.example.com,s3.eu-west-1.amazonaws.com
# EMAIL_ASSET_URL_HOSTS=*
# Upload asset da admin Email (opzionale): bucket S3 + credenziali AWS standard.
# EMAIL_FLOW_S3_BUCKET=my-bucket
# EMAIL_FLOW_S3_PUBLIC_BASE_URL=https://cdn.example.com  # opzionale se URL diversa da s3.amazonaws.com
# Asset workspace (immagini progetto, planimetrie): bucket S3; se assente usa EMAIL_FLOW_S3_BUCKET
# ASSETS_S3_BUCKET=my-assets-bucket
#
# Outlook / Microsoft Graph (calendario): obbligatori per GET /v1/connectors/outlook/auth e callback.
# OUTLOOK_REDIRECT_URI deve coincidere esattamente con un "Redirect URI" dell'app in Azure (tipo Web).
# Esempio locale con PORT=8080:
# OUTLOOK_REDIRECT_URI=http://localhost:8080/v1/connectors/outlook/callback
# OUTLOOK_CLIENT_ID=
# OUTLOOK_CLIENT_SECRET=
# Opzionale: tenant Azure AD (default common = account personali + work/school)
# OUTLOOK_TENANT_ID=common
# Dopo OAuth, redirect al frontend (senza slash finale):
# OUTLOOK_FRONTEND_REDIRECT_BASE=http://localhost:5177
